#  Database 
# Local dev (outside Docker): use localhost:5433
# Inside Docker: overridden by docker-compose environment block (postgres:5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/document_editor

#  Security -
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

#  App 
APP_TITLE=Regulatory Service
APP_VERSION=1.0.0

#  CORS 
ALLOWED_ORIGINS=*

#  Media / File Storage 
# Local dev: points to the doc_media symlink -> D:\doc_media
# Inside Docker: overridden by docker-compose to /app/doc_media
MEDIA_ROOT=D:\doc_media
MEDIA_URL=/media
