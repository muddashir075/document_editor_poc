# ─── Media / File Storage ─────────────────────────────────────────────────────
# Absolute path to the folder where uploaded .docx files are stored.
# On Windows this should point to D:\doc_media (the symlink regulatory_service/doc_media targets this).
# On Linux/Mac set to any writable absolute path.
MEDIA_ROOT=D:\doc_media
# URL prefix under which files are served by FastAPI StaticFiles
MEDIA_URL=/media

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, good for local dev)
DATABASE_URL=sqlite:///./regulatory.db

# PostgreSQL example (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/regulatory_db

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# ─── App ──────────────────────────────────────────────────────────────────────
APP_TITLE=Regulatory Service
APP_VERSION=1.0.0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
