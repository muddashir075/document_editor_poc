#  PostgreSQL 
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

#  Zitadel 
# 32-byte base64 master key (44 chars). Generate your own:
# python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_KEY=vbQkEeg4Jm2sj8GMfiKXCut7zDWcxLlU

# Zitadel DB admin (must match POSTGRES_USER / POSTGRES_PASSWORD above)
ZITADEL_DB_ADMIN_USER=postgres
ZITADEL_DB_ADMIN_PASSWORD=postgres

# Zitadel application DB user (Zitadel creates this user itself)
ZITADEL_DB_APP_USER=zitadel
ZITADEL_DB_APP_PASSWORD=zitadel_pass

# Zitadel first-instance admin account
ZITADEL_ADMIN_USERNAME=admin@zitadel.localhost
ZITADEL_ADMIN_PASSWORD=Admin1234!
