# Backend API base URL (Vite proxy handles /api in dev, set full URL for production)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket base URL
VITE_WS_BASE_URL=ws://localhost:8000

# Media base URL — used to build download links for uploaded .docx files
VITE_MEDIA_BASE_URL=http://localhost:8000/media

# Current logged-in user (placeholder until auth is wired)
VITE_DEFAULT_USER=admin
