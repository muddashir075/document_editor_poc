# Backend API base URL
# Local dev: Vite proxy handles /api -> backend, so this can stay as localhost
# Docker: set to the actual backend address accessible from the browser
VITE_API_BASE_URL=http://192.168.100.238:5001

# WebSocket base URL
VITE_WS_BASE_URL=ws://192.168.100.238:5001

# Media files base URL
VITE_MEDIA_BASE_URL=http://192.168.100.238:5001/media

# Default user for demo (no real auth yet)
VITE_DEFAULT_USER=admin
